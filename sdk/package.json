{
  "name": "@jhonata-matias/flux-client",
  "version": "0.1.0",
  "description": "TypeScript SDK for the servegate (ex-gemma4) FLUX image-generation gateway (Story 2.5). Handles cold-start (~130s) via warmup() + retry-with-backoff, exposes typed errors (ColdStartError, RateLimitError, ValidationError, AuthError, NetworkError). Repo: Jhonata-Matias/servegate.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "tsup",
    "pack:dry": "npm pack --dry-run",
    "publish:gh": "npm publish --registry=https://npm.pkg.github.com",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "flux",
    "ai",
    "image-generation",
    "runpod",
    "sdk",
    "servegate",
    "gemma4"
  ],
  "author": "Jhonata Matias",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jhonata-Matias/servegate.git"
  },
  "bugs": {
    "url": "https://github.com/Jhonata-Matias/servegate/issues"
  },
  "homepage": "https://github.com/Jhonata-Matias/servegate#readme",
  "license": "MIT",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
